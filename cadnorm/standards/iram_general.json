{
  "metadata": {
    "standard_name": "IRAM",
    "standard_version": "XXVII",
    "effective_date": "1990-01-01",
    "source": "IRAM 4501 (Vistas — Método ISO E), IRAM 4502 (Líneas), IRAM 4503 (Letras y números), IRAM 4504 (Formatos, elementos gráficos y plegado), IRAM 4505 (Escalas lineales para construcciones civiles y mecánicas), IRAM 4507 (Secciones y cortes), IRAM 4508 (Rótulo, lista de materiales y despiezo), IRAM 4509 (Rayados indicadores de secciones y cortes), IRAM 4513 (Acotación de planos en dibujo mecánico)",
    "profile_version": "1.1.0",
    "description": "Perfil normativo IRAM para dibujo técnico de ingeniería civil y arquitectura. Basado en el Manual de Normas de Aplicación para Dibujo Técnico, Edición XXVII. Cubre formatos A0–A4 (IRAM 4504), tipos de línea (IRAM 4502), escritura normalizada (IRAM 4503), escalas (IRAM 4505), rótulo (IRAM 4508) y acotamiento (IRAM 4513).",
    "software_targets": ["autocad", "librecad"],
    "country": "AR"
  },

  "units": {
    "system": "metric",
    "linear_unit": "mm",
    "linear_precision": 0,
    "angular_unit": "degrees",
    "angular_precision": 0,
    "insertion_scale": "mm",
    "measurement_system": 1
  },

