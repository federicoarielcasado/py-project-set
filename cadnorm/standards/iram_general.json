{
  "metadata": {
    "standard_name": "IRAM",
    "standard_version": "2001",
    "effective_date": "2001-01-01",
    "source": "IRAM 4503:2001 - Dibujo técnico. Formatos. IRAM 4504 - Tipos de línea. IRAM 4040 - Escalas. IRAM 4508 - Escritura. IRAM 4049 - Acotamiento.",
    "profile_version": "1.0.0",
    "description": "Perfil normativo IRAM para dibujo técnico de ingeniería civil y arquitectura. Cubre formatos A0-A4, tipos de línea ISO, escritura normalizada y acotamiento IRAM 4503.",
    "software_targets": ["autocad", "librecad"],
    "country": "AR"
  },

  "units": {
    "system": "metric",
    "linear_unit": "mm",
    "linear_precision": 2,
    "angular_unit": "degrees",
    "angular_precision": 0,
    "insertion_scale": "mm",
    "measurement_system": 1
  },

